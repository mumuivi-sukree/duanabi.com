---
// src/components/DuaWord.astro
const { ar, read, mean } = Astro.props;
---
<div class="flex flex-col items-center justify-start min-w-[110px] max-w-fit p-4 h-full">
  <div class="text-4xl md:text-5xl mb-3 text-slate-900 leading-[2.2] font-serif">
    {ar}
  </div>
  <div class="text-[13px] md:text-sm text-slate-500 font-medium whitespace-nowrap">
    {read}
  </div>
  <div class="text-[11px] md:text-xs text-emerald-700 text-center leading-snug mt-1">
    [{mean}]
  </div>
</div>