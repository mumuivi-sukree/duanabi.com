---
import DuaWord from './DuaWord.astro';
const { duaData } = Astro.props;
---
<section class="bg-white p-6 md:p-10 rounded-3xl my-6 border border-slate-100 shadow-sm">
  <h3 class="text-slate-400 text-sm font-medium mb-6 border-b border-slate-200/50 pb-2 w-fit">
    คำต่อคำ (Word by Word)
  </h3>
  <div class="dua-container-force not-prose">
    {duaData.map((item) => (
      <DuaWord {...item} />
    ))}
  </div>
</section>