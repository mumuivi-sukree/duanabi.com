---
// src/components/DuaPagination.astro
interface Props {
  prevUrl?: string;
  nextUrl?: string;
}
const { prevUrl, nextUrl } = Astro.props;
---

<div class="grid grid-cols-3 gap-2 mt-12 pt-8 border-t border-slate-100">
  
  {/* ปุ่มก่อนหน้า */}
  {prevUrl ? (
    <a href={prevUrl} class="flex items-center justify-center py-3 px-2 bg-slate-50 rounded-xl text-slate-600 font-bold no-underline hover:bg-slate-100 transition-all text-sm border border-slate-200/50">
      ← ก่อนหน้า
    </a>
  ) : <div />}

  {/* ปุ่มกลับไปบนสุด */}
  <button 
    onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
    class="flex items-center justify-center py-3 px-2 bg-white rounded-xl text-slate-400 font-bold border border-slate-200 hover:bg-slate-50 transition-all text-sm cursor-pointer"
  >
    ↑ บนสุด
  </button>

  {/* ปุ่มหน้าถัดไป */}
  {nextUrl ? (
    <a href={nextUrl} class="flex items-center justify-center py-3 px-2 bg-slate-800 rounded-xl text-white font-bold no-underline hover:bg-slate-900 transition-all text-sm shadow-sm">
      ถัดไป →
    </a>
  ) : <div />}

</div>