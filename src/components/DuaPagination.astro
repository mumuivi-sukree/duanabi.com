---
// src/components/DuaPagination.astro
interface Props {
  prevUrl?: string;
  nextUrl?: string;
}
const { prevUrl, nextUrl } = Astro.props;
---

<div class="grid grid-cols-3 gap-3 mt-12 pt-8 border-t border-slate-100">
  
  {/* ปุ่มก่อนหน้า */}
  {prevUrl ? (
    <a href={prevUrl} class="flex items-center justify-center gap-1 py-3 px-2 bg-blue-600 rounded-xl !text-white font-bold no-underline hover:bg-blue-800 transition-all text-xs shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      ก่อนหน้า
    </a>
  ) : <div />}

  {/* ปุ่มกลับไปบนสุด */}
  <button 
    onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
    class="flex items-center justify-center gap-1 py-3 px-2 bg-slate-200 rounded-xl !text-slate-700 font-bold border border-slate-200 hover:bg-slate-400 transition-all text-xs cursor-pointer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    บนสุด
  </button>

  {/* ปุ่มหน้าถัดไป */}
  {nextUrl ? (
    <a href={nextUrl} class="flex items-center justify-center gap-1 py-3 px-2 bg-blue-600 rounded-xl !text-white font-bold no-underline hover:bg-blue-800 transition-all text-xs shadow-sm">
      ถัดไป
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </a>
  ) : <div />}

</div>